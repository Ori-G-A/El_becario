# Copia este archivo a .env.test para habilitar los E2E autenticados.
# .env.test esta ignorado por Git y debe existir solo durante el desarrollo.

# Debe coincidir con VITE_SUPABASE_URL y confirmar deliberadamente el proyecto.
E2E_PROJECT_REF=TU-PROYECTO

# Usa una cuenta dedicada. El valor debe incluir e2e, test, qa o playwright.
E2E_EMAIL=becario+e2e@tu-dominio.example

# Se usa solo desde Node/Playwright. Nunca agregues el prefijo VITE_.
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY_SECRETA
