# El Becario — variables de entorno
# Copia este archivo a `.env.local` y completa los valores reales.
# NUNCA comitees `.env.local` (está ignorado en .gitignore).
#
# La anon key es PÚBLICA por diseño: lo que protege tus datos es el RLS,
# no el secreto de esta clave. (Ver schema.sql — RLS en todas las tablas.)

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY_PUBLICA

# Clave PÚBLICA VAPID para Web Push (la privada va en los secretos de GitHub).
# Generar con: pnpm exec web-push generate-vapid-keys --json
VITE_VAPID_PUBLIC_KEY=TU_CLAVE_PUBLICA_VAPID
